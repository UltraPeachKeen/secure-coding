# openssl rand -hex 32 명령으로 새 값을 생성하세요.
SECRET_KEY=replace-with-a-random-secret-at-least-32-bytes
# 선택 사항: 기본값은 프로젝트의 instance/market.db 및 uploads/입니다.
# DATABASE_URL=sqlite:////absolute/path/to/market.db
# UPLOAD_FOLDER=/absolute/path/to/uploads
MAX_CONTENT_LENGTH=2097152
REPORT_THRESHOLD=3
INITIAL_BALANCE=100000
COOKIE_SECURE=false
# seed-demo 실행 전에만 원하는 값으로 설정하고 공개 저장소에는 실제 값을 넣지 마세요.
DEMO_PASSWORD=DemoPassword!234
